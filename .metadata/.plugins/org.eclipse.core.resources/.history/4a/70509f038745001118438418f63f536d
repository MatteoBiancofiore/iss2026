QActor syncer context ctxfireflysynch {
	
	[# 
		var Timer = 10000L
		var Frequency = 0L
		var DMIN = 50
	#]
	
	State initSync initial {
		[# Frequency = java.util.Random().nextLong(500L,1000L) #]
		
		println("$name started...") color red	
		println("$name : Initializing 10sec timer...") color red
	}
	Transition t0 
			whenTimeVar Timer -> timerHandler
			whenEvent sonar_data -> handle_sonar
			
	
	State timerHandler {
		println("$name | Synchronizing with frequency $Frequency") color blue
		emit syn : syn($Frequency)
		delayVar Frequency
	}
	Goto timerHandler
	
	State handle_sonar {
		onMsg (sonar_data : distance(Distance)) {
			[# var D = payloadArg(0).toInt() #]
			
			println("$name: Current sonar distance = $D") color magenta
			
			if [# D < DMIN #] {
				emit syn : syn($Frequency) // sync
			}
			else {
				 forward firefly1 -m stop_syn : stop_syn
				 forward firefly2 -m stop_syn : stop_syn
				 forward firefly3 -m stop_syn : stop_syn
			}
		}
	}
	Goto handle_sonar
	
}

QActor sonar context ctxfireflysynch {
	
	State init initial {
		println("Sonar started...") color green
	}
	Goto emitData
	
	State emitData {
		
		[# var Distance = java.util.Random().nextInt(10, 100) #]
		emit sonar_data : distance($Distance)
		delay 5000
	}
	Goto emitData
	
}