System firefly

Dispatch cellstate : cellstate(X,Y,COLOR)

Context ctxfirefly ip [ host="localhost" port=8040 ]
Context ctxgrid ip [host="localhost" port=8050 ] // contesto remoto

QActor firefly1 context ctxfirefly {
	
	[#
		var X = 1
		var Y = 1
	#]
	
	State s0 initial {
		println("$name started") color green
	}
	Goto flash
	
	State flash {
		[# var Timer = java.util.Random().nextLong(500L,1000L ) #]
		delayVar Timer
		//TurnoOn
		//println("$name | turnOn $Timer") color magenta
	    forward griddisplay -m cellstate : cellstate($X,$Y,1)
	    delayVar Timer	
	    //TurnoOff
	    //println("$name | turnOff $Timer") color magenta
	    forward griddisplay -m cellstate : cellstate($X,$Y,0)
	}
	// Goto flash
}

QActor griddisplaymock context ctxfirefly {
	
	State s0 initial {
		println("$name started") color green
	}
	Transition t0 
		whenMsg cellstate -> elabMsg
		
		
	State elabMsg {
		
		printCurrentMessage color blue
		
	}
}