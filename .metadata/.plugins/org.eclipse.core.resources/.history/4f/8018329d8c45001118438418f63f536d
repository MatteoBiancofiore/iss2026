System fireflysync

Dispatch cellstate : cellstate(X,Y,COLOR)
Event syn : syn(FREQUENCY)
Event sonar_data : distance(D)
Dispatch stop_syn : stop_syn(0)

Context ctxfireflysynch ip [ host="localhost" port=8040 ]
Context ctxgrid ip [host="127.0.0.1" port=8050 ] // contesto remoto

ExternalQActor griddisplay context ctxgrid //definizione attore esterno al sistema, essendo un attore esterno non ha stati


// ========== FIREFLY 1 ==========

QActor firefly1 context ctxfireflysynch {
	
	[#
		var X = 1
		var Y = 1
		var Frequency = java.util.Random().nextLong(500L, 1000L)
	#]
	
	State randomFlash initial {
		forward griddisplay -m cellstate : cellstate($X,$Y,1)
	    delayVar Frequency
	    forward griddisplay -m cellstate : cellstate($X,$Y,0)
	}
	Transition t0 
			whenTimeVar Frequency -> randomFlash
			whenEvent syn -> syncedFlash
		

	State syncedFlash {
		onMsg(syn : syn(Frequency)){
			[# Frequency = payloadArg(0).toLong() #]
	    	println("$name | Synchronizing to $Frequency ms") color yellow	
		}
		forward griddisplay -m cellstate : cellstate($X,$Y,1)
	    delayVar Frequency
	    forward griddisplay -m cellstate : cellstate($X,$Y,0)
	    delayVar Frequency
	}
	Transition t1 
		whenEvent syn -> syncedFlash
		whenMsg stop_syn -> randomFlash		 

}

