	    delayVar Frequency
	}
	Transition t1 
		whenEvent syn -> syncedFlash
		whenMsg stop_syn -> randomFlash		 

}

QActor syncer context ctxfireflysynch {
	[# 
		var Frequency = 600L
		var DMIN = 50
		var StartTime = 0L
		var IsPermanent = false
		var IsSonarSync = false
	#]
	
	State s0 initial {
		[# 
            StartTime = System.currentTimeMillis() 
            Frequency = java.util.Random().nextLong(500L,1000L)
        #]
		println("$name | 10s countdown...") color red	
	}
	Goto work

	State work {
		[# 
            // Verifico se i 10s sono passati (Requisito A)
            if(!IsPermanent && (System.currentTimeMillis() - StartTime) > 10000) {
                IsPermanent = true
                println("$name | 10 SECONDI SCADUTI: Sync Permanente!") color red
            }
        #]
        if [# IsPermanent || IsSonarSync #] {
            emit syn : syn($Frequency)
        }
	}
    // Questo loop permette di non "perdere" mai il conto dei 10 secondi
	Transition t0 whenTimeVar Frequency -> work
	              whenEvent sonar_data  -> handleSonar
			
	State handleSonar {
		onMsg (sonar_data : distance(D)) {
			[# 
                var Dist = payloadArg(0).toInt() 
                IsSonarSync = (Dist < DMIN) 
            #]
			println("$name | Sonar: $Dist | Sync Temporanea: $IsSonarSync") color red
			
			if [# !IsSonarSync && !IsPermanent #] {
				forward firefly1 -m stop_syn : stop_syn(0)
				forward firefly2 -m stop_syn : stop_syn(0)
				forward firefly3 -m stop_syn : stop_syn(0)
			}
		}
	}
	Goto work
}

QActor sonar context ctxfireflysynch {
	
	State init initial {
		println("$name started...") color green
	}
	Goto emitData
	
	State emitData {
		
		[# var Distance = java.util.Random().nextInt(10, 100) #]
		emit sonar_data : distance($Distance)
		delay 5000
	}
	Goto emitData
	
}