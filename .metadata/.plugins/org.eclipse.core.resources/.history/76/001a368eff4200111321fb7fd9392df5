System firefly

Dispatch cellstate : cellstate(X,Y,COLOR)

Context ctxfirefly ip [ host="localhost" port=8040 ]
Context ctxgrid ip [host="localhost" port=8050 ]

QActor firefly1 context ctxfirefly {
	
	[#
		var X = 1
		var Y = 1
	#]
	
	State s0 initial {
		println("$name started") color green
	}
	Goto flash
	
	State flash {
		[# var Timer = java.util.Random().nextLong(500L,1000L ) #]
		delayVar Timer
		//TurnoOn
		//println("$name | turnOn $Timer") color magenta
	    forward griddisplaymock -m cellstate : cellstate($X,$Y,1)
	    delayVar Timer	
	    //TurnoOff
	    //println("$name | turnOff $Timer") color magenta
	    forward griddisplaymock -m cellstate : cellstate($X,$Y,0)
	}
	// Goto flash
}

QActor griddisplaymock context ctxgrid {
	
	[#
 		val javalin = guiout.JavalinGuiHandler("javalinh", 8080) 
 		//javalin solo OUT: NON emette eventi cmd e cell
 		javalin.setUpPageGranular()
 	#]
	State s0 initial{
		println("$name | starts") color blue	
	} 
	Goto work 

	State work{
		println("$name | waiting ... ") color blue	
	}	
	Transition t0
		whenMsg   cellstate -> handleCell
		whenEvent cellstate -> handleCell
		
	State handleCell{
		printCurrentMessage
		onMsg( cellstate : cellstate(X,Y,C) ){
			[# var X = payloadArg(0)  
			   var Y = payloadArg(1) 
			   var C = payloadArg(2) 
			#]
			println("X=$X Y=$Y C=$C")
			[#  javalin.changeCellState(X,Y,C) #]
		} 
	}
	Goto work 
}