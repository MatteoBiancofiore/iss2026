package main.java.conway.domain;

public class Cell implements ICell {

	private boolean status;
	
	public Cell() {
		status = false;
	}
	
	public Cell(boolean status) {
		this.status = status;
	}

	@Override
	public void setStatus(boolean status) {
		this.status = status;	
	}

	@Override
	public boolean getStatus() {
		return this.status;
	}
	
}
